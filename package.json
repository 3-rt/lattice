{
  "name": "lattice",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/adapters/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "start": "npx tsx packages/relay/src/main.ts",
    "dev:relay": "npm run dev --workspace=packages/relay",
    "dev:dashboard": "npm run dev --workspace=packages/dashboard",
    "dev:all": "npm run dev:relay & npm run dev:dashboard",
    "dev": "npm run dev:relay",
    "demo": "bash scripts/demo.sh"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.0"
  }
}
