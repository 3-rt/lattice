{
  "name": "Incident Response",
  "description": "Production incident comes in — one agent triages the stack trace, another writes the fix, a third reviews it for safety, and the team gets notified with a summary.",
  "definition": {
    "nodes": [
      {
        "id": "triage",
        "type": "agent-task",
        "label": "Triage Incident",
        "config": {
          "agent": "claude-code",
          "taskTemplate": "Triage this production incident. Analyze the stack trace, identify the root cause, and classify severity:\n\n{{incidentReport}}"
        }
      },
      {
        "id": "fix",
        "type": "agent-task",
        "label": "Write Fix",
        "config": {
          "agent": "claude-code",
          "taskTemplate": "Write a fix for this incident based on the triage analysis:\n\n{{triageResult}}"
        }
      },
      {
        "id": "review",
        "type": "agent-task",
        "label": "Security Review",
        "config": {
          "agent": "codex",
          "taskTemplate": "Review this fix for security vulnerabilities, correctness, and potential regressions:\n\n{{fixOutput}}"
        }
      },
      {
        "id": "check-review",
        "type": "condition",
        "label": "Review Passed?",
        "config": {
          "field": "review.status",
          "operator": "equals",
          "value": "completed"
        }
      },
      {
        "id": "notify",
        "type": "agent-task",
        "label": "Summarize Resolution",
        "config": {
          "agent": "auto",
          "taskTemplate": "Write a short incident resolution summary (5 lines max) based on:\n\nTriage: {{triageResult}}\nFix: {{fixOutput}}\nReview: {{reviewOutput}}"
        }
      }
    ],
    "edges": [
      {
        "source": "triage",
        "target": "fix",
        "dataMapping": {
          "artifacts[0].parts[0].text": "triageResult"
        }
      },
      {
        "source": "fix",
        "target": "review",
        "dataMapping": {
          "artifacts[0].parts[0].text": "fixOutput"
        }
      },
      {
        "source": "review",
        "target": "check-review"
      },
      {
        "source": "check-review",
        "target": "notify"
      },
      {
        "source": "triage",
        "target": "notify",
        "dataMapping": {
          "artifacts[0].parts[0].text": "triageResult"
        }
      },
      {
        "source": "fix",
        "target": "notify",
        "dataMapping": {
          "artifacts[0].parts[0].text": "fixOutput"
        }
      },
      {
        "source": "review",
        "target": "notify",
        "dataMapping": {
          "artifacts[0].parts[0].text": "reviewOutput"
        }
      }
    ]
  }
}
